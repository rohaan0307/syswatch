# === syswatch backend configuration ===

# Backend: anthropic | ollama | groq | openrouter
SYSWATCH_BACKEND=anthropic

# Model (must be valid for the chosen backend)
SYSWATCH_MODEL=claude-opus-4-5

# Base URL (mainly for Ollama, e.g. http://localhost:11434)
# SYSWATCH_BASE_URL=

# API key for the active backend
ANTHROPIC_API_KEY=sk-ant-...
